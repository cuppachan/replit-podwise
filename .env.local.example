# Copy this file to .env.local and fill in values if needed.
# For local development, these are already wired up by run-local.sh.
# You only need this file if you want to override defaults.

# Port the API server binds to (default: 5000)
# PORT=5000

# Full URL the Expo app uses to reach the API server (default: http://localhost:5000)
# EXPO_PUBLIC_DOMAIN=http://localhost:5000

# Only required if you use the DB features (not needed for v1 local-only storage)
# DATABASE_URL=postgresql://postgres@localhost/podwise

# Session secret for Express — generate with: openssl rand -hex 32
# SESSION_SECRET=your-secret-here
